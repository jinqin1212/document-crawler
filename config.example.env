WENSHU_USER=
WENSHU_PASS=
OUTPUT_DIR=./data
HEADLESS=false
# 首次登录：设为 true 且终端执行 PWDEBUG=1 python main.py，在 Inspector 里 Resume 继续
WENSHU_LOGIN_PAUSE=false
# 默认 true：自动点顶栏「登录」；若出现 WAF 页请在浏览器内完成验证，脚本会等待并尽量回到检索页
# 不需要时可设 false
WENSHU_CLICK_NAV_LOGIN=true
# true：首页普通搜索——填关键词后点 div.search-rightBtn.search-click（见 wenshu_selectors.home_search_click）
# false：走高级检索 #keyValue1（民事/判决书/日期）
WENSHU_SIMPLE_SEARCH_ONLY=false
# 列表翻页上限（阶段 2）；每页间隔随机 1.5～4 秒
MAX_PAGES=5
# 登录态 JSON：先运行 python save_storage_state.py 生成，再把路径填到下面
# 例：STORAGE_STATE_PATH=./data/wenshu_state.json
STORAGE_STATE_PATH=
# 阶段 1 检索条件（可选）
SEARCH_KEYWORD=腾讯电子签
SEARCH_DATE_START=2000-01-01
SEARCH_DATE_END=2026-03-28

# --- 阶段 3：详情 HTML（python fetch_details.py）---
DETAIL_LIST_JSON=./data/wenshu_list_preview.json
DETAIL_OUTPUT_DIR=./data/raw
# 用于解析列表里的相对链接 ../xxx/index.html?docId=...
DETAIL_URL_BASE=https://wenshu.court.gov.cn/website/wenshu/181029CR4M5A62CH/index.html
DETAIL_RETRIES=3
DETAIL_MAX_ITEMS=0
# true：已存在的非空 html 跳过
DETAIL_SKIP_EXISTING=true
DETAIL_DELAY_MIN=1.5
DETAIL_DELAY_MAX=4.0
DETAIL_FAILED_LOG=./data/failed_cases.txt
# 详情页：组合选择器最长等待(ms)；稳定延时(秒)。调小可更快落盘（若 HTML 缺正文再调大）
DETAIL_BODY_TIMEOUT_MS=8000
DETAIL_STABILIZE_S=0.5

# --- 阶段 4：解析 HTML（python parser.py）---
PARSER_RAW_DIR=./data/raw
PARSER_OUT_CSV=./data/wenshu_parsed_preview.csv
PARSER_OUT_JSON=./data/wenshu_parsed_preview.json

# --- 阶段 5：导出正式表（python export_cases.py）---
EXPORT_INPUT_CSV=./data/wenshu_parsed_preview.csv
EXPORT_OUT_CSV=./data/wenshu_cases.csv
EXPORT_OUT_XLSX=./data/wenshu_cases.xlsx
# true：在表里保留 raw_标的片段 列
EXPORT_KEEP_RAW_SNIPPET=false

# --- 阶段 6：图表（python analysis.py）---
ANALYSIS_INPUT_CSV=./data/wenshu_cases.csv
ANALYSIS_PLOTS_DIR=./data/plots
